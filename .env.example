# Anthropic API Key - Required for Claude LLM access
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI API Key - Required for generating text embeddings (text-embedding-3-small)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Default Claude model to use for RAG responses
# See available models: https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-4-5

# Embedding model from OpenAI used for document chunk vectorization
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small

# Vector database connection string (PostgreSQL with pgvector extension)
# For local dev: postgresql://user:password@localhost:5432/ragdb
# For hosted options see: https://supabase.com or https://neon.tech
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# Directory where uploaded PDF/document files will be stored
# Ensure this path exists and is writable by the API process
UPLOAD_DIR=./uploads

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Chunk size in characters for splitting documents before embedding
# Smaller = more precise retrieval, larger = more context per chunk
CHUNK_SIZE=1000

# Overlap in characters between consecutive chunks to preserve context
CHUNK_OVERLAP=200

# Number of top relevant chunks to retrieve for each RAG query
TOP_K_RESULTS=5

# FastAPI server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Environment name: development, staging, production
ENVIRONMENT=development

# Secret key for signing API tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-secret-string

# Optional: Logfire token for observability and tracing pydantic-ai agents
# Get yours at: https://logfire.pydantic.dev/
LOGFIRE_TOKEN=